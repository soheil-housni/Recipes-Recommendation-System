import torch
import torch.nn as nn
import mmh3

class RecommendationModel(nn.Module):
    def __init__(self,
                 n_recipe_ids,
                 recipe_id_emb_dim
                 ):
        super().__init__()

        self.n_recipe_ids=n_recipe_ids
        self.bucket_size=int(0.05*self.n_recipe_ids)
        self.recipe_id_emb_dim=recipe_id_emb_dim

        self.recipe_id_embedding_matrix=torch.zeros((self.n_recipe_ids+1,recipe_id_emb_dim))

        for i in range(self.n_recipe_ids):
            self.recipe_id_embedding_matrix[i,:] = [mmh3.hash(str(i), seed=k) % self.bucket_size for k in range(1024)]
        



